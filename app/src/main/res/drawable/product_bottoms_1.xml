<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#5D2A2A"
                android:endColor="#3A1A1A"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="140dp" android:height="100dp"/>
            <corners android:radius="6dp" />
            <solid android:color="#7A4444" />
        </shape>
    </item>
</layer-list>
