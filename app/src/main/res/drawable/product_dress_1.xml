<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#F8E1E1"
                android:endColor="#FFB3D9"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="120dp" android:height="200dp"/>
            <corners android:radius="60dp" />
            <solid android:color="#FF80B0" />
        </shape>
    </item>
</layer-list>
