<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#FFF2F2"
                android:endColor="#F2C4C4"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="120dp" android:height="160dp"/>
            <corners android:radius="8dp" />
            <solid android:color="#E5A5A5" />
        </shape>
    </item>
</layer-list>
