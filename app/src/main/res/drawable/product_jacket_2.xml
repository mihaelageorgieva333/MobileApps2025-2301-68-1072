<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#A89078"
                android:endColor="#6B5840"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="130dp" android:height="190dp"/>
            <corners android:radius="8dp" />
            <solid android:color="#8B7860" />
        </shape>
    </item>
</layer-list>
