<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#F8E1E1"
                android:endColor="#E5A5A5"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="100dp" android:height="140dp"/>
            <solid android:color="#D98B8B" />
        </shape>
    </item>
</layer-list>
