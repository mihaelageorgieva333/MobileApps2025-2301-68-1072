<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#5D2A2A"
                android:endColor="#7A4444"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="100dp" android:height="170dp"/>
            <corners android:radius="6dp" />
            <solid android:color="#8B5555" />
        </shape>
    </item>
</layer-list>
