<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#F8E1E1"
                android:endColor="#E5A5A5"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="130dp" android:height="100dp"/>
            <corners android:radius="6dp" />
            <solid android:color="#F2C4C4" />
        </shape>
    </item>
</layer-list>
